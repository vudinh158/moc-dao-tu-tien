{
  "info": {
    "_postman_id": "moc-dao-tu-tien-sqa-test",
    "name": "Mộc Đạo Tu Tiên — SQA Test Collection",
    "description": "Bộ kịch bản kiểm thử API cho dự án IoT Gamification 'Mộc Đạo Tu Tiên' (v2 - Delta Sync & Multi-plant).\n\nÁnh xạ 1:1 với các Test Case trong báo cáo SQA cuối kỳ.\n\nHướng dẫn:\n1. Import file này vào Postman.\n2. Đặt biến `base_url` = http://localhost:8000\n3. Chạy lần lượt từ trên xuống hoặc dùng Collection Runner.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "plant_code",
      "value": "ESP8888",
      "type": "string"
    },
    {
      "key": "verify_code",
      "value": "123456",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. Health Check",
      "item": [
        {
          "name": "HC-01: Server is alive",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Kiểm tra server đang chạy. Expected: HTTP 200."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Server is alive', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. UC-01: Liên kết Chậu cây (Pairing)",
      "item": [
        {
          "name": "TC-01.0: Tự cấp mã nạp mạch (DIY Provisioning)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/plants/diy-provision",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "diy-provision"
              ]
            },
            "description": "Tự cấp mã (DIY). Expected: 200, trả về plant_code và verify_code."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('DIY Provisioning — HTTP 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('plant_code', jsonData.data.plant_code);",
                  "    pm.collectionVariables.set('verify_code', jsonData.data.verify_code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-01.1: Happy Path — Liên kết thành công",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plant_code\": \"{{plant_code}}\",\n  \"verify_code\": \"{{verify_code}}\",\n  \"plant_name\": \"Tiểu Mộc\",\n  \"plant_type_id\": \"uuid-of-kim-tien\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/plants/pair",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "pair"
              ]
            },
            "description": "TC-01.1: Gửi đúng Plant Code + Verify Code + User hợp lệ.\nExpected: HTTP 201, tạo record trong bảng plants."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-01.1: Liên kết thành công — HTTP 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('TC-01.1: Response chứa plant_id', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('plant_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-01.2: Sai mã thiết bị — Plant Code không tồn tại",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plant_code\": \"FAKE9999\",\n  \"verify_code\": \"{{verify_code}}\",\n  \"plant_name\": \"Test\",\n  \"plant_type_id\": \"uuid-of-kim-tien\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/plants/pair",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "pair"
              ]
            },
            "description": "TC-01.2: Plant Code không tồn tại trong DB.\nExpected: HTTP 400/404, thông báo lỗi 'Mã không hợp lệ'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-01.2: Sai mã — HTTP 400 hoặc 404', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-01.3: Sai Verify Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plant_code\": \"{{plant_code}}\",\n  \"verify_code\": \"WRONG_CODE\",\n  \"plant_name\": \"Test\",\n  \"plant_type_id\": \"uuid-of-kim-tien\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/plants/pair",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "pair"
              ]
            },
            "description": "TC-01.3: Plant Code đúng nhưng Verify Code sai.\nExpected: HTTP 400, 'Mã xác thực không đúng'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-01.3: Verify sai — HTTP 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-01.4: Thiết bị đã có chủ (BUG-001)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plant_code\": \"{{plant_code}}\",\n  \"verify_code\": \"{{verify_code}}\",\n  \"plant_name\": \"Test Trùng\",\n  \"plant_type_id\": \"uuid-of-kim-tien\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/plants/pair",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "pair"
              ]
            },
            "description": "TC-01.4: Thiết bị đã được liên kết bởi User khác.\nExpected: HTTP 400, 'Thiết bị đã được liên kết'.\nLưu ý: Trước BUG-001 fix, endpoint trả HTTP 500."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-01.4: Thiết bị trùng — HTTP 400 (sau fix BUG-001)', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-01.5: Liên kết chậu thứ 2 (Multi-plant)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plant_code\": \"{{plant_code_2}}\",\n  \"verify_code\": \"{{verify_code_2}}\",\n  \"plant_name\": \"Cây thứ 2\",\n  \"plant_type_id\": \"uuid-of-kim-tien\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/plants/pair",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "pair"
              ]
            },
            "description": "Liên kết cây thứ 2. Expected: HTTP 201."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-01.5: Đa chậu thành công — HTTP 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. UC-02: Dashboard & Sensors",
      "item": [
        {
          "name": "TC-02.1: Lấy Dashboard thành công",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/plants/me/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "me",
                "dashboard"
              ]
            },
            "description": "TC-02.1: Lấy dữ liệu Dashboard: 4 chỉ số cảm biến, Tu Vi, Cảnh Giới.\nExpected: HTTP 200, response chứa total_exp và rank."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-02.1: Dashboard — HTTP 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('TC-02.1: Response chứa total_exp', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('total_exp');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. UC-03: Lịch sử Cảm biến (History Chart)",
      "item": [
        {
          "name": "TC-03.1: Lấy lịch sử Soil Moisture 24h",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/plants/me/history?sensor_key=soil_moisture&hours=24",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "me",
                "history"
              ],
              "query": [
                {
                  "key": "sensor_key",
                  "value": "soil_moisture"
                },
                {
                  "key": "hours",
                  "value": "24"
                }
              ]
            },
            "description": "TC-03.1: Lấy lịch sử cảm biến độ ẩm 24h để vẽ Line chart.\nExpected: HTTP 200, response chứa mảng datapoints."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-03.1: History API — HTTP 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. UC-04: Bảng Xếp Hạng (Leaderboard)",
      "item": [
        {
          "name": "TC-04.1: Lấy Top 10 Leaderboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/leaderboard?limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "leaderboard"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "TC-04.1: Lấy bảng xếp hạng Top 10.\nExpected: HTTP 200, response chứa mảng items sắp xếp giảm dần theo total_exp."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-04.1: Leaderboard — HTTP 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('TC-04.1: Response chứa items array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('items');",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Telemetry v2 (Delta Sync)",
      "item": [
        {
          "name": "TC-05.1: Gửi Telemetry (Không cộng EXP trực tiếp)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Plant-Code",
                "value": "{{plant_code}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"soil_moisture\": 35.0,\n  \"light\": 500,\n  \"temperature\": 28.5,\n  \"humidity\": 65.0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/devices/{{plant_code}}/telemetry",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "devices",
                "{{plant_code}}",
                "telemetry"
              ]
            },
            "description": "TC-05.1: Gửi Telemetry.\nExpected: HTTP 200, lưu lại trạng thái mới nhất. Không trả về exp_added."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-05.1: Telemetry v2 — HTTP 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "6. Security Testing",
      "item": [
        {
          "name": "TC-06.1: Authorization — Truy cập cây người khác",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/plants/me/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "me",
                "dashboard"
              ]
            },
            "description": "TC-06.1: Dùng JWT của User A để truy cập resource.\nAPI /plants/me đảm bảo chỉ trả dữ liệu của chính user đang đăng nhập.\nExpected: HTTP 200 nhưng chỉ trả dữ liệu của owner, không lộ data người khác."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-06.1: Chỉ trả data của owner', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-SEC.1: Truy cập không có JWT",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/plants/me/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "me",
                "dashboard"
              ]
            },
            "description": "TC-SEC.1: Gọi API bảo mật mà KHÔNG có Authorization header.\nExpected: HTTP 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-SEC.1: Thiếu JWT — HTTP 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-SEC.2: JWT Token hết hạn / giả mạo",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.INVALID.TOKEN"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/plants/me/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "plants",
                "me",
                "dashboard"
              ]
            },
            "description": "TC-SEC.2: Gửi JWT token giả mạo / đã hết hạn.\nExpected: HTTP 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-SEC.2: Token giả — HTTP 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-SEC.3: User thường truy cập API Admin",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard"
              ]
            },
            "description": "TC-SEC.3: User thường (không phải Admin) cố truy cập API Admin.\nExpected: HTTP 403 Forbidden."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-SEC.3: User thường vào Admin — HTTP 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "7. SQA Static Analysis",
      "item": [
        {
          "name": "TC-SQA.1: Ruff Linter (chạy ngoài Postman)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "TC-SQA.1: Chạy lệnh 'uv run ruff check .' trên Terminal.\nExpected: Exit code 0, không có cảnh báo.\nLưu ý: Test này chạy ngoài Postman, request này chỉ là placeholder."
          }
        }
