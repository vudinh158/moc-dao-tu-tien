# Copy file này thành .env và điền đúng giá trị

# URL backend FastAPI (uvicorn mặc định cổng 8000)
VITE_BACKEND_URL=http://localhost:8000

# Prefix cho axios — giữ nguyên /api, Vite proxy sẽ tự forward
VITE_API_URL=/api

# Google OAuth Client ID (phải khớp GOOGLE_CLIENT_ID bên backend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
