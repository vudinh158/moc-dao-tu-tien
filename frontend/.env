# URL backend FastAPI (uvicorn chạy ở cổng 8000)
VITE_BACKEND_URL=http://localhost:8000

# Prefix cho axios — giữ nguyên /api, Vite proxy sẽ forward sang backend
VITE_API_URL=/api

